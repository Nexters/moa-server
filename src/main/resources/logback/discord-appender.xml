<included>
    <springProperty name="discordWebhookUri" source="logging.discord.webhook-uri"/>

    <appender name="DISCORD" class="com.github.napstr.logback.DiscordAppender">
        <webhookUri>${discordWebhookUri}</webhookUri>
        <layout class="ch.qos.logback.classic.PatternLayout">
            <pattern>🚨 [%-5level] %msg%n🕒 %d{yyyy-MM-dd HH:mm:ss.SSS} | 🧵 %thread%n🆔 request=%X{requestId:-?} |
                member=%X{memberId:-?}%n📍 %logger{36}%n```%ex{full}```
            </pattern>
        </layout>
        <username>Spring</username>
        <avatarUrl>
            https://cdn.freebiesupply.com/logos/large/2x/spring-3-logo-png-transparent.png
        </avatarUrl>
        <tts>false</tts>
    </appender>

    <appender name="ASYNC_DISCORD" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="DISCORD"/>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
    </appender>
</included>
